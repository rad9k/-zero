<my:ZoomScrollViewBasedVisualiserBase xmlns:Controls="clr-namespace:m0_COMPOSER.UIWpf.Visualisers.Control"  x:Class="m0_COMPOSER.UIWpf.Visualisers.SongVisualiser"
             xmlns:my="clr-namespace:m0_COMPOSER.UIWpf.Visualisers"
             xmlns:m0="clr-namespace:m0.UIWpf;assembly=m0_desktop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:m0_COMPOSER.UIWpf.Visualisers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" KeyDown="KeyDownHandler">
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Name="RewindButton" ToolTip="Rewind" Click="RewindButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/rewind.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
                <ToggleButton Name="PlayButton" ToolTip="Play" Click="PlayButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/play.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="RecordButton" ToolTip="Record" Click="RecordButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/record.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <Button Name="StopButton" ToolTip="Stop" Click="StopButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/stop.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
                <ToggleButton Name="RepeatButton" ToolTip="Repeat" Click="RepeatButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/repeat.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

            </ToolBar>
            <ToolBar>
                <ToggleButton Name="ArrowButton_Instance" ToolTip="Select multiple sequences" Click="ArrowButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/pointer.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="PenButton_Instance" ToolTip="Add sequence" Click="PenButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/pen.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="EraseButton_Instance" ToolTip="Erase sequence" Click="EraseButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/eraser.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="RazorButton_Instance" ToolTip="Cut sequence" Click="RazorButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/razor.jpg" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Name="GlueButton_Instance" ToolTip="Merge sequences" Click="GlueButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/glue.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

            </ToolBar>
            <ToolBar>

                <Button Name="CutButton_Instance" ToolTip="Cut sequences" Click="CutButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/cut.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0">Cut</TextBlock>
                    </StackPanel>
                </Button>
                <Button Name="CopyButton_Instance" ToolTip="Copy sequences" Click="CopyButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/copy.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0">Copy</TextBlock>
                    </StackPanel>
                </Button>
                <Button Name="PasteButton_Instance" ToolTip="Paste sequences" Click="PasteButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/paste.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0">Paste</TextBlock>
                    </StackPanel>
                </Button>

            </ToolBar>
            <ToolBar Name="TimeToolbar">

                <TextBlock Name="Time" FontFamily="Consolas" FontSize="17"></TextBlock>

                <Separator/>

                <Button Name="TruncateButton_Instance" ToolTip="Truncate the sequence length" Click="TruncateButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/truncate.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Name="ExtendButton_Instance" ToolTip="Extend the sequence length" Click="ExtendButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/extend.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
                
                <Separator/>
                
                <m0:VisualiserEditWrapper x:Name="TempoVisualiser" Width="150"/>

                <Separator/>

                <Button Name="MuteSpeakerButton_Instance" ToolTip="Silence on all MIDI devices" Click="MuteSpeakerButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,/m0_COMPOSER;Component/_resources/basic/mute-speaker.png" Width="15" Height="15"/>
                        <TextBlock Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        <Controls:ZoomScrollView x:Name="ZoomScrollView_Instance" DownAreaVisible="True"/>
    </DockPanel>
</my:ZoomScrollViewBasedVisualiserBase>
