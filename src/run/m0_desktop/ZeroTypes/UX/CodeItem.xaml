<my:RectangleItem_LabeledItem x:Class="m0.ZeroTypes.UX.CodeItem"
             xmlns:my="clr-namespace:m0.ZeroTypes.UX"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             >

    <Border x:Name="Frame"  BorderBrush="{StaticResource 0ForegroundBrush}" BorderThickness="1" HorizontalAlignment="Stretch"  VerticalAlignment="Stretch">
        <Grid x:Name="TheGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="17"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" x:Name="LabelContainer" Padding="3,0,3,0" />

            <Border x:Name="InternalFrame" Grid.Row="1"  BorderThickness="0" Background="{StaticResource 0ForegroundBrush}"/>

        </Grid>

    </Border>


</my:RectangleItem_LabeledItem>
