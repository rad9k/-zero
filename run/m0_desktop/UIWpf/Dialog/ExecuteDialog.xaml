<UserControl x:Class="m0.UIWpf.Dialog.ExecuteDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Visualisers="clr-namespace:m0.UIWpf.Visualisers"
             xmlns:UIWpf="clr-namespace:m0.UIWpf"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="500" Background="{StaticResource 0BackgroundBrush}" Foreground="{StaticResource 0ForegroundBrush}" Unloaded="UserControl_Unloaded">


    <Grid>
        <Grid Margin="0,0,0,48.4" >

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">
                <TextBlock HorizontalAlignment="Left" Height="22" Margin="10,10,0,0" TextWrapping="Wrap" Text="Input Stack Vertex" VerticalAlignment="Top"/>
                <Border BorderThickness="1" BorderBrush="{StaticResource 0ForegroundBrush}" Margin="10,32,10,0" Height="20" VerticalAlignment="Top" x:Name="InputStackEdgeControl_Border"/>



                <TextBlock Margin="10,76,0,0" Text="Input Stack Content" VerticalAlignment="Top" HorizontalAlignment="Left"  Height="22"  Width="97" TextWrapping="Wrap"/>
                <Border BorderThickness="1" BorderBrush="{StaticResource 0ForegroundBrush}" Margin="10,94,10,10" x:Name="InputStackContentControl_Border"/>
               

            </Grid>

            <Grid Grid.Column="1">
                <TextBlock HorizontalAlignment="Left" Height="22" Margin="10,10,0,0" TextWrapping="Wrap" Text="Output Stack Vertex" VerticalAlignment="Top"/>
                <Border BorderThickness="1" BorderBrush="{StaticResource 0ForegroundBrush}" Margin="10,32,10,0" Height="20" VerticalAlignment="Top" x:Name="OutputStackEdgeControl_Border"/>

                <TextBlock Margin="10,76,0,0" Text="Output Stack Content" VerticalAlignment="Top" HorizontalAlignment="Left"  Height="22"  Width="97" TextWrapping="Wrap"/>
                <Border BorderThickness="1" BorderBrush="{StaticResource 0ForegroundBrush}" Margin="10,94,10,10" x:Name="OutputStackContentControl_Border" />

            </Grid>

        </Grid>
                        
        
        <Button x:Name="ExecuteButton" Content="Execute" Margin="0,0,10,10.4" HorizontalAlignment="Right" Width="107" Height="33" VerticalAlignment="Bottom" Click="ExecuteButton_Click"/>

    </Grid>
</UserControl>
